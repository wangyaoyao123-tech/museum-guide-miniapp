/* pages/exhibits/exhibits.wxss — 展品列表页样式（含信息流广告、底部 Banner） */

.container {
  background: var(--bg-color, #f5f5f5);
  min-height: 100vh;
}

/* ── 搜索栏 ─────────────────────────────────────────────────────── */
.search-bar {
  padding: 16rpx 24rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}
.search-inner {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 14rpx 24rpx;
  gap: 12rpx;
}
.search-icon { font-size: 28rpx; color: #999; }
.search-input { flex: 1; font-size: 28rpx; color: #333; background: transparent; }
.search-clear { font-size: 28rpx; color: #bbb; padding: 0 4rpx; }

/* ── 分类 Tab ────────────────────────────────────────────────────── */
.category-scroll { background: #fff; border-bottom: 1rpx solid #f0f0f0; }
.category-tabs { display: inline-flex; padding: 0 16rpx; gap: 8rpx; white-space: nowrap; }
.cat-tab {
  display: inline-block;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
  white-space: nowrap;
}
.cat-tab.active {
  color: #c8a96e;
  border-bottom-color: #c8a96e;
  font-weight: bold;
}

/* ── 展品列表 ───────────────────────────────────────────────────── */
.exhibit-list { padding: 16rpx 24rpx; display: flex; flex-direction: column; gap: 16rpx; }
.exhibit-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  align-items: center;
}
.exhibit-img { width: 180rpx; height: 160rpx; flex-shrink: 0; }
.exhibit-info { flex: 1; padding: 20rpx 16rpx; overflow: hidden; }
.exhibit-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #222;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.exhibit-period { display: block; font-size: 22rpx; color: #999; margin-bottom: 6rpx; }
.exhibit-hall { display: block; font-size: 22rpx; color: #888; margin-bottom: 10rpx; }
.exhibit-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.tag { font-size: 20rpx; background: #f0f0f0; color: #666; padding: 4rpx 12rpx; border-radius: 20rpx; }
.exhibit-right {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 20rpx;
  gap: 8rpx;
}
.audio-icon { font-size: 36rpx; }
.arrow { font-size: 36rpx; color: #ccc; }

/* ── 信息流原生广告卡（强制标注「广告」，风格与展品卡统一） ────── */
.native-ad-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  align-items: center;
  position: relative;
  border: 1rpx solid #f5e8c8;
}
/* 「广告」合规标识（右上角角标） */
.native-ad-label {
  position: absolute;
  top: 0; right: 0;
  font-size: 18rpx;
  color: #fff;
  background: #c8a96e;
  padding: 4rpx 14rpx;
  border-radius: 0 16rpx 0 10rpx;
}
.native-ad-img { width: 160rpx; height: 130rpx; flex-shrink: 0; }
.native-ad-info { flex: 1; padding: 20rpx 16rpx; overflow: hidden; }
.native-ad-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.native-ad-desc { display: block; font-size: 22rpx; color: #999; }
.native-ad-arrow { font-size: 36rpx; color: #ccc; padding: 0 20rpx; }

/* ── 空状态 ─────────────────────────────────────────────────────── */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #999; }

/* ── 底部 Banner 广告 ───────────────────────────────────────────── */
.bottom-placeholder { height: 120rpx; }
.bottom-banner {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: 120rpx;
  background: #fff;
  border-top: 1rpx solid #ebebeb;
  display: flex;
  align-items: center;
  z-index: 100;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.06);
}
.banner-ad-img { flex: 1; height: 100%; display: block; }
.banner-ad-label {
  position: absolute;
  left: 10rpx; top: 8rpx;
  font-size: 18rpx;
  color: #fff;
  background: rgba(0,0,0,0.38);
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}
.banner-close-btn {
  position: absolute;
  right: 0; top: 0;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  background: rgba(0,0,0,0.28);
  border-radius: 0 0 0 12rpx;
}
