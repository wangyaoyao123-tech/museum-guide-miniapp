/* pages/unlock/unlock.wxss */
.container {
  min-height: 100vh;
  background: var(--bg-color, #f5f5f5);
  padding-bottom: 60rpx;
}

/* 已解锁 */
.unlocked-view {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}
.unlocked-icon { font-size: 100rpx; margin-bottom: 30rpx; }
.unlocked-title { font-size: 40rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; }
.unlocked-desc { font-size: 28rpx; color: #666; margin-bottom: 60rpx; }
.go-btn {
  background: linear-gradient(135deg, #c8a96e, #a07840);
  color: #fff;
  font-size: 32rpx;
  padding: 24rpx 80rpx;
  border-radius: 50rpx;
  border: none;
}

/* Hero */
.hero {
  background: linear-gradient(160deg, #1a1a2e, #16213e);
  padding: 60rpx 40rpx 50rpx;
  text-align: center;
}
.hero-icon { font-size: 80rpx; display: block; margin-bottom: 20rpx; }
.hero-title { display: block; font-size: 44rpx; font-weight: bold; color: #fff; margin-bottom: 12rpx; }
.hero-subtitle { font-size: 28rpx; color: rgba(255,255,255,0.7); }

/* 权益卡片 */
.benefits-card {
  margin: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}
.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}
.benefit-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 20rpx;
}
.benefit-item:last-child { border-bottom: none; }
.benefit-icon { font-size: 44rpx; width: 60rpx; text-align: center; }
.benefit-info { flex: 1; }
.benefit-title { display: block; font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 4rpx; }
.benefit-desc { font-size: 24rpx; color: #999; }
.benefit-check { color: #66bb6a; font-size: 32rpx; font-weight: bold; }

/* 价格卡片 */
.price-card {
  margin: 0 24rpx 24rpx;
  background: linear-gradient(135deg, #fff8e1, #fff3cd);
  border: 2rpx solid #f0c040;
  border-radius: 20rpx;
  padding: 24rpx 30rpx;
}
.price-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.price-label { font-size: 30rpx; font-weight: bold; color: #333; }
.price-right { display: flex; align-items: baseline; gap: 12rpx; }
.price-original { font-size: 26rpx; color: #999; text-decoration: line-through; }
.price-current { font-size: 48rpx; font-weight: bold; color: #e53935; }
.price-tip { font-size: 24rpx; color: #f57c00; }

/* 支付按钮 */
.pay-section { padding: 0 24rpx; }
.pay-btn {
  width: 100%;
  background: linear-gradient(135deg, #c8a96e, #a07840);
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  padding: 28rpx;
  border-radius: 50rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(160,120,64,0.4);
  margin-bottom: 20rpx;
}
.pay-btn.loading { opacity: 0.7; }
.pay-tip { display: block; text-align: center; font-size: 22rpx; color: #999; }
.link { color: #c8a96e; }

/* FAQ */
.faq-section { margin: 30rpx 24rpx 0; }
.faq-title { display: block; font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; }
.faq-item { margin-bottom: 20rpx; }
.faq-q { display: block; font-size: 26rpx; color: #555; margin-bottom: 6rpx; }
.faq-a { display: block; font-size: 24rpx; color: #888; line-height: 1.6; }
