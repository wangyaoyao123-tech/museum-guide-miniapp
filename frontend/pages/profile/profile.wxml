<!-- pages/profile/profile.wxml — 个人中心 -->
<!-- 广告合规：激励视频为主动点击触发，无自动弹出；底部 Banner 可一键关闭 -->
<view class="container">

  <!-- 用户信息头部 -->
  <view class="header">
    <view class="avatar-wrap">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default_avatar.png'}}" mode="aspectFill"/>
    </view>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickName || '游客'}}</text>
      <view class="free-badge">
        <text>🎵 语音讲解免费开放</text>
      </view>
    </view>
  </view>

  <!-- 免广告特权状态卡（激励视频生效期间展示） -->
  <view class="ad-free-card" wx:if="{{isAdFree && rewardVideoCfg}}">
    <text class="ad-free-icon">🎬</text>
    <view class="ad-free-info">
      <text class="ad-free-title">免广告特权生效中</text>
      <text class="ad-free-sub">剩余 {{adFreeRemain}} 分钟 · 全程无广告体验</text>
    </view>
  </view>

  <!-- 激励视频广告入口（主动点击，无自动弹出；每日最多 2 次） -->
  <view class="menu-section" wx:if="{{rewardVideoCfg && rewardVideoCfg.is_active}}">
    <text class="menu-title">广告特权</text>
    <view class="menu-list">
      <view class="menu-item reward-entry" bindtap="onWatchRewardVideo">
        <text class="menu-icon">🎬</text>
        <view class="menu-label-wrap">
          <text class="menu-label">{{rewardVideoCfg.entry_text}}</text>
          <text class="menu-sub" wx:if="{{isAdFree}}">特权生效中 · 剩余 {{adFreeRemain}} 分钟</text>
          <text class="menu-sub" wx:else>今日还可观看 {{rewardRemainToday}} 次</text>
        </view>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 服务与支持功能菜单 -->
  <view class="menu-section">
    <text class="menu-title">服务与支持</text>
    <view class="menu-list">
      <view class="menu-item" bindtap="onAboutTap">
        <text class="menu-icon">🏛️</text>
        <text class="menu-label">关于我们</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onContactTap">
        <text class="menu-icon">📞</text>
        <text class="menu-label">联系客服</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goAgreement">
        <text class="menu-icon">📄</text>
        <text class="menu-label">用户协议</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="goPrivacy">
        <text class="menu-icon">🔐</text>
        <text class="menu-label">隐私政策</text>
        <text class="menu-arrow">›</text>
      </view>
      <view class="menu-item" bindtap="onClearCache">
        <text class="menu-icon">🗑️</text>
        <text class="menu-label">清除缓存</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <text class="version">版本 v1.1.0</text>

  <!-- 底部安全占位 -->
  <view class="bottom-placeholder" wx:if="{{showBanner && !isAdFree}}"></view>
</view>

<!-- 底部 Banner 广告（轻量化窄条，可一键关闭，关闭后 30 分钟内不再展示） -->
<view class="bottom-banner" wx:if="{{showBanner && bannerAd && !isAdFree}}">
  <image class="banner-ad-img" src="{{bannerAd.image}}" mode="aspectFill" bindtap="onBannerTap"/>
  <view class="banner-ad-label">广告</view>
  <view class="banner-close-btn" catchtap="onCloseBanner">✕</view>
</view>
