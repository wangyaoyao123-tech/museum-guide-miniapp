/* pages/profile/agreement.wxss & privacy.wxss 共用样式 */
.container {
  min-height: 100vh;
  background: #fff;
}
.content {
  padding: 40rpx 32rpx 80rpx;
  display: flex;
  flex-direction: column;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a2e;
  margin-bottom: 12rpx;
}
.update-time {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 40rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #222;
  margin-top: 36rpx;
  margin-bottom: 12rpx;
}
.body-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
}
